<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:client.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="client.Views.LoginPageView"
             xmlns:vm="clr-namespace:client.ViewModels" x:DataType="vm:LoginPageViewModel"
             xmlns:converter="clr-namespace:client.Models.Convertors">
  
    <UserControl.Resources>
        <converter:TextToVisibilityConverter x:Key="TTVConverter"/>
    </UserControl.Resources>

    <Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition></ColumnDefinition>
			<ColumnDefinition Width="auto"></ColumnDefinition>
			<ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
			<RowDefinition></RowDefinition>
			<RowDefinition Height="auto"></RowDefinition>
			<RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Border Classes="Roundy" Grid.Row="1" Grid.Column="1">
            <StackPanel Spacing="5">
			    <TextBox Text="{Binding Login}" Watermark="Логин" MinWidth="200" CornerRadius="10"></TextBox>
			    <TextBox Text="{Binding Password}" Watermark="Пароль" CornerRadius="10"></TextBox>
			    <TextBlock Text="{Binding Warning}" IsVisible="{Binding Warning, Converter={StaticResource TTVConverter}}"></TextBlock>
                <Button HorizontalAlignment="Center" Margin="0,10,0,0" Content="Войти"></Button>
            </StackPanel>
        </Border>
        <Button Content="Регистрация" Grid.Column="2" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="15"></Button>
    </Grid>


</UserControl>
